<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ListInfoActivity">

    <Button
        android:id="@+id/GoToCompareSearchButton"
        android:layout_width="113dp"
        android:layout_height="52dp"
        android:layout_marginTop="4dp"
        android:text="Siirry vertailuun"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/GoToVisaButton"
        android:layout_width="120dp"
        android:layout_height="53dp"
        android:text="Siirry visaan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.106"
        app:layout_constraintStart_toEndOf="@+id/GoToCompareSearchButton"
        tools:layout_editor_absoluteY="4dp" />

    <Button
        android:id="@+id/GoToHomeButton"
        android:layout_width="142dp"
        android:layout_height="54dp"
        android:text="Siirry kuntahakuun"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.992"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>